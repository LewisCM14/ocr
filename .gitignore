# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── UV ────────────────────────────────────────────────────────────────────────
# Keep uv.lock committed (reproducible installs); ignore the cache
.uv/

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Environment / secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── OCR pipeline runtime artefacts ───────────────────────────────────────────
# Processed output (mirrors input tree under output_root)
ocr_output/

# Uploaded / source images — typically managed outside the repo
images/
*.tif
*.tiff

# Temporary / local config overrides (keep config.yaml.example committed)
config.local.yaml
